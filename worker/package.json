{
  "name": "paygate-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute paygate --local --file=./migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute paygate --remote --file=./migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute paygate --local --file=./migrations/0002_seed.sql",
    "db:seed:remote": "wrangler d1 execute paygate --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "wrangler": "^3.95.0"
  }
}
